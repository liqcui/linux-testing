// TCP 三次握手基本测试
// 测试目的: 验证 TCP 连接建立过程

// 建立 TCP socket
0.000 socket(..., SOCK_STREAM, IPPROTO_TCP) = 3
0.000 setsockopt(3, SOL_SOCKET, SO_REUSEADDR, [1], 4) = 0
0.000 bind(3, ..., ...) = 0
0.000 listen(3, 1) = 0

// 三次握手 - 第一步: 客户端发送 SYN
0.100 < S 0:0(0) win 65535 <mss 1460,sackOK,nop,nop,nop,wscale 7>

// 三次握手 - 第二步: 服务器回复 SYN-ACK
// 注意: 使用实际内核返回的 TCP 选项顺序
0.100 > S. 0:0(0) ack 1 win 65535 <mss 1460,nop,nop,sackOK,nop,wscale 7>

// 三次握手 - 第三步: 客户端发送 ACK
0.200 < . 1:1(0) ack 1 win 65535

// accept() 应该成功返回新连接
0.200 accept(3, ..., ...) = 4

// 测试简单的数据传输
0.300 write(4, ..., 1000) = 1000
0.300 > P. 1:1001(1000) ack 1 win 65535

// 正常关闭连接
0.400 close(4) = 0
0.400 > F. 1001:1001(0) ack 1 win 65535
